# VaultGuard Extension Environment Variables
# 
# This file contains default environment variables for development
# 
# Override with:
# - .env.development (for npm run dev)
# - .env.staging (for npm run build:staging)
# - .env.production (for npm run build:prod)

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Debug Configuration
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# Extension Configuration
VITE_ENVIRONMENT=development
VITE_VERSION=2.0.0

# Feature Flags
VITE_FEATURE_BIOMETRIC=false
VITE_FEATURE_SHARING=false
VITE_FEATURE_2FA=false

# Session Configuration
VITE_SESSION_TIMEOUT=1800000
VITE_TOKEN_REFRESH_INTERVAL=300000

# Security Configuration
VITE_ENFORCE_HTTPS=false
VITE_ALLOW_INSECURE_STORAGE=false
